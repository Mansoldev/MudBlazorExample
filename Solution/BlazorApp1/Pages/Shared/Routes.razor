@using Microsoft.AspNetCore.Components.Routing
@rendermode InteractiveServer

<Router AppAssembly="typeof(Program).Assembly" NotFoundPage="typeof(Pages.Shared.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Pages.Shared.Layouts.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
